# Normalizar finales de línea al subir a GitHub (LF en el repo, CRLF en Windows)
* text=auto

# Forzar LF en archivos de código
*.js    text eol=lf
*.jsx   text eol=lf
*.ts    text eol=lf
*.tsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.env*  text eol=lf
*.sh    text eol=lf

# Binarios — no tocar
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
