# ─────────────────────────────────────────────────────────────
#  VARIABLES DE ENTORNO — Sistema Ferretería (Frontend)
#  Copiar como .env.production antes de ejecutar npm run build.
#  Las variables VITE_* quedan embebidas en el bundle de producción.
# ─────────────────────────────────────────────────────────────

# URL base del backend desplegado (sin barra final, sin /api)
# Ejemplo: https://api.ferreteria.tudominio.com
VITE_API_URL=https://api.tudominio.com
