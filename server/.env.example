# ─────────────────────────────────────────────────────────────
#  VARIABLES DE ENTORNO — Sistema Ferretería (Backend)
#  Copiar este archivo a .env y completar los valores reales.
#  NUNCA commitear el archivo .env al repositorio.
# ─────────────────────────────────────────────────────────────

# ── Servidor ─────────────────────────────────────────────────
PORT=3002
NODE_ENV=production

# ── Base de datos MySQL ───────────────────────────────────────
# En Railway estos valores los copia directamente del servicio MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=tu_usuario_mysql
DB_PASSWORD=tu_contraseña_segura
DB_NAME=ferreteria_db
DB_DIALECT=mysql
# Activar solo si Railway exige conexión SSL (normalmente no es necesario)
DB_SSL=false

# ── Autenticación JWT ─────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=reemplazar_con_clave_aleatoria_de_64_caracteres_minimo
JWT_EXPIRES_IN=8h

# ── CORS ─────────────────────────────────────────────────────
# URL del frontend desplegado (sin barra final)
# Ejemplo: https://ferreteria.tudominio.com
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
# Máximo de intentos de login por IP en 15 minutos
LOGIN_RATE_LIMIT_MAX=10
